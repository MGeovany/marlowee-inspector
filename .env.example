# ── Auth.js (Microsoft Entra ID / OIDC) ──────────────────────────────────────
# Generate with: openssl rand -base64 32
AUTH_SECRET=

# Public base URL of the app
AUTH_URL=http://localhost:4444

# From the "Marlowee Inspector" App Registration (to be created in Entra ID — NOT by this repo)
# Leave AUTH_MICROSOFT_ENTRA_ID_ID EMPTY for local dev: the app falls back to a
# one-click "Continue as Dev" login (no Azure changes). Set it to enable real Entra OIDC.
AUTH_MICROSOFT_ENTRA_ID_ID=
AUTH_MICROSOFT_ENTRA_ID_SECRET=
# v2.0 issuer for the Savvly tenant
AUTH_MICROSOFT_ENTRA_ID_ISSUER=https://login.microsoftonline.com/cac58ef5-e1ea-4641-9663-a6d848ad392f/v2.0

# Dev-only: role the bypass session is granted (Admin | Developer | QA | Support | Viewer).
# Ignored once AUTH_MICROSOFT_ENTRA_ID_ID is set. See §4 role matrix.
AUTH_DEV_ROLE=Admin

# ── Azure Log Analytics ──────────────────────────────────────────────────────
AZURE_TENANT_ID=cac58ef5-e1ea-4641-9663-a6d848ad392f
# law-savvly-dev-main (customerId / workspace GUID) — confirmed by discovery
AZURE_LOG_ANALYTICS_WORKSPACE_ID=e583009c-5c01-4d42-a46a-3c771e087f5d

# Optional production setting: user-assigned Managed Identity client id.
# Leave empty for local az-login dev; DefaultAzureCredential is used in both cases.
AZURE_MANAGED_IDENTITY_CLIENT_ID=

# ── App config ───────────────────────────────────────────────────────────────
RATE_LIMIT_PER_MINUTE=30

# NOTE: never add NEXT_PUBLIC_ to any secret above. All values are server-only.
